## colorlight_i9.lpf — Pin constraints for Cap-Scale on Colorlight i9 v7.2
## FPGA: LFE5U-45F-6BG381C
##
## Pin reuse from CCD project:
##   FM_PIN  → TX_POS_PIN  (excitation positive)
##   SH_PIN  → TX_NEG_PIN  (excitation negative)
##   ICG_PIN → MUX_SEL[0]  (CD4052 A)
##   FLASH_0 → MUX_SEL[1]  (CD4052 B)

## ---- 25 MHz Oscillator ----
LOCATE COMP "CLK_25M" SITE "P3";
IOBUF  PORT "CLK_25M" IO_TYPE=LVCMOS33;
FREQUENCY PORT "CLK_25M" 25 MHZ;

## ---- ADC Data D[7:0] ----
LOCATE COMP "ADC_D0"  SITE "C4";
LOCATE COMP "ADC_D1"  SITE "B4";
LOCATE COMP "ADC_D2"  SITE "A3";
LOCATE COMP "ADC_D3"  SITE "F5";
LOCATE COMP "ADC_D4"  SITE "E4";
LOCATE COMP "ADC_D5"  SITE "A2";
LOCATE COMP "ADC_D6"  SITE "F4";
LOCATE COMP "ADC_D7"  SITE "E1";

IOBUF  PORT "ADC_D0"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D1"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D2"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D3"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D4"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D5"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D6"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D7"  IO_TYPE=LVCMOS33;

## ---- ADC Data D[11:8] + Control Outputs ----
LOCATE COMP "ADC_D8"      SITE "M3";
LOCATE COMP "ADC_D9"      SITE "N2";
LOCATE COMP "ADC_D10"     SITE "T2";
LOCATE COMP "ADC_D11"     SITE "N4";
LOCATE COMP "ADC_CLK_PIN" SITE "N3";   ## Clock to AD9226 (sample trigger)

IOBUF  PORT "ADC_D8"      IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D9"      IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D10"     IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D11"     IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_CLK_PIN" IO_TYPE=LVCMOS33;

## ---- Excitation Drive (reuse FM/SH pin sites) ----
LOCATE COMP "TX_POS_PIN" SITE "M4";   ## Was FM_PIN — TX+ excitation
LOCATE COMP "TX_NEG_PIN" SITE "L4";   ## Was SH_PIN — TX- excitation

IOBUF  PORT "TX_POS_PIN" IO_TYPE=LVCMOS33 DRIVE=8;
IOBUF  PORT "TX_NEG_PIN" IO_TYPE=LVCMOS33 DRIVE=8;

## ---- Analog Mux Select (reuse ICG + FLASH_0 pin sites) ----
LOCATE COMP "MUX_SEL[0]" SITE "K5";   ## Was ICG_PIN — CD4052 A
LOCATE COMP "MUX_SEL[1]" SITE "C1";   ## Was FLASH_0 — CD4052 B

IOBUF  PORT "MUX_SEL[0]" IO_TYPE=LVCMOS33 DRIVE=8;
IOBUF  PORT "MUX_SEL[1]" IO_TYPE=LVCMOS33 DRIVE=8;

## ---- UART ----
LOCATE COMP "UART_TX" SITE "D1";      ## FPGA → host
LOCATE COMP "UART_RX" SITE "E2";      ## host → FPGA

IOBUF  PORT "UART_TX" IO_TYPE=LVCMOS33;
IOBUF  PORT "UART_RX" IO_TYPE=LVCMOS33 PULLMODE=UP;

## ---- SPI to RP2040 ----
LOCATE COMP "SPI_SCK"  SITE "F1";
LOCATE COMP "SPI_MOSI" SITE "G2";
LOCATE COMP "SPI_MISO" SITE "H1";
LOCATE COMP "SPI_CS_N" SITE "G1";

IOBUF  PORT "SPI_SCK"  IO_TYPE=LVCMOS33;
IOBUF  PORT "SPI_MOSI" IO_TYPE=LVCMOS33;
IOBUF  PORT "SPI_MISO" IO_TYPE=LVCMOS33;
IOBUF  PORT "SPI_CS_N" IO_TYPE=LVCMOS33 PULLMODE=UP;

## ---- Onboard LED ----
## LOCATE COMP "LED" SITE "L2";
## IOBUF  PORT "LED" IO_TYPE=LVCMOS33;
